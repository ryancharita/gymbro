generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum SplitDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SplitVisibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum SplitStatus {
  DRAFT
  PUBLISHED
}

enum SetType {
  STRAIGHT
  SUPERSET
  DROP_SET
  AMRAP
  TIME_BASED
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  FOREARMS
  ABS
  QUADS
  HAMSTRINGS
  GLUTES
  CALVES
  FULL_BODY
  CARDIO
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model User {
  id                 String    @id @default(cuid())
  clerkId            String    @unique @map("clerk_id")
  username           String?   @unique
  email              String?
  bio                String?
  profilePhotoUrl    String?   @map("profile_photo_url")
  city               String?
  gymName            String?   @map("gym_name")
  experienceLevel    String?   @map("experience_level")
  trainingStyleTags  String[]  @default([]) @map("training_style_tags")
  goals              String[]  @default([])
  onboardingComplete Boolean   @default(false) @map("onboarding_complete")
  isPrivateProfile   Boolean   @default(false) @map("is_private_profile")
  notifyOnFollow     Boolean   @default(true) @map("notify_on_follow")
  notifyOnLike       Boolean   @default(true) @map("notify_on_like")
  notifyOnComment    Boolean   @default(true) @map("notify_on_comment")
  notifyWeeklySummary Boolean  @default(true) @map("notify_weekly_summary")
  optOutBuddyFinder  Boolean   @default(false) @map("opt_out_buddy_finder")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  splits          Split[]
  routines        Routine[]
  customExercises Exercise[]     @relation("CustomExercises")
  sessions        WorkoutSession[]
  followers       Follow[]       @relation("Following")
  following       Follow[]       @relation("Follower")
  posts           Post[]

  @@index([clerkId])
  @@map("users")
}

model Split {
  id              String          @id @default(cuid())
  userId          String          @map("user_id")
  name            String
  description     String?
  daysPerWeek     Int             @map("days_per_week")
  difficulty      SplitDifficulty
  experienceLevel String?         @map("experience_level")
  visibility      SplitVisibility @default(PRIVATE)
  status          SplitStatus     @default(DRAFT)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  days SplitDay[]

  @@index([userId])
  @@map("splits")
}

model SplitDay {
  id        String  @id @default(cuid())
  splitId   String  @map("split_id")
  label     String
  dayOrder  Int     @map("day_order")
  routineId String? @map("routine_id")

  split   Split    @relation(fields: [splitId], references: [id], onDelete: Cascade)
  routine Routine? @relation(fields: [routineId], references: [id])

  @@unique([splitId, dayOrder])
  @@map("split_days")
}

model Routine {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises RoutineExercise[]
  splitDays SplitDay[]
  sessions  WorkoutSession[]

  @@index([userId])
  @@map("routines")
}

model Exercise {
  id              String        @id @default(cuid())
  name            String
  primaryMuscles  MuscleGroup[] @map("primary_muscles")
  secondaryMuscles MuscleGroup[] @map("secondary_muscles")
  equipment       String[]
  movementPattern String?       @map("movement_pattern")
  videoUrl        String?       @map("video_url")
  isCustom        Boolean       @default(false) @map("is_custom")
  userId          String?       @map("user_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user            User?             @relation("CustomExercises", fields: [userId], references: [id], onDelete: Cascade)
  routineExercises RoutineExercise[]
  workoutSets     WorkoutSet[]

  @@index([name])
  @@index([userId])
  @@map("exercises")
}

model RoutineExercise {
  id           String  @id @default(cuid())
  routineId    String  @map("routine_id")
  exerciseId   String  @map("exercise_id")
  setType      SetType @default(STRAIGHT) @map("set_type")
  sets         Int
  repsMin      Int?    @map("reps_min")
  repsMax      Int?    @map("reps_max")
  weightTarget Float?  @map("weight_target")
  restSeconds  Int?    @map("rest_seconds")
  notes        String?
  sortOrder    Int     @map("sort_order")

  routine  Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([routineId, sortOrder])
  @@map("routine_exercises")
}

model WorkoutSession {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  routineId   String?       @map("routine_id")
  startedAt   DateTime      @default(now()) @map("started_at")
  completedAt DateTime?     @map("completed_at")
  status      SessionStatus @default(IN_PROGRESS)
  notes       String?

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine Routine?     @relation(fields: [routineId], references: [id])
  sets    WorkoutSet[]

  @@index([userId, startedAt])
  @@map("workout_sessions")
}

model WorkoutSet {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  exerciseId  String   @map("exercise_id")
  setNumber   Int      @map("set_number")
  setType     SetType  @default(STRAIGHT) @map("set_type")
  weight      Float?
  reps        Int?
  durationSec Int?     @map("duration_sec")
  isCompleted Boolean  @default(false) @map("is_completed")
  isPr        Boolean  @default(false) @map("is_pr")
  createdAt   DateTime @default(now()) @map("created_at")

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id])

  @@index([sessionId])
  @@index([exerciseId])
  @@map("workout_sets")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model Post {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  content   String
  imageUrl  String?  @map("image_url")
  splitId   String?  @map("split_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("posts")
}
